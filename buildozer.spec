[app]

# (str) Title of your application
title = Maestro de Fútbol

# (str) Package name
package.name = maestrofutbol

# (str) Package domain (needed for android)
package.domain = com.damian

# (str) Source code where the main.py lives
source.dir = .

# (list) Source files to include
source.include_exts = py,png,jpg,kv,atlas,json,sh

# (str) Main script to run
source.main = updater.py

check_requirements = 0
# (list) Application requirements
requirements = python3,requests

# (str) Application version
version = 0.1

# (list) Permissions
android.permissions = INTERNET





